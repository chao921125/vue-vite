{
  "name": "vue-vite",
  "version": "4.0.2",
  "private": true,
  "description": "vue-vite",
  "keywords": [
    "admin",
    "pina",
    "vite",
    "vue",
    "vue-router",
    "vue2",
    "vue3"
  ],
  "homepage": "https://github.com/chao921125/vue-vite",
  "bugs": {
    "url": "https://github.com/chao921125/vue-vite/issues"
  },
  "license": "BSD-3-Clause",
  "author": {
    "name": "chao921125",
    "email": "chao921125@sina.com",
    "url": "https://github.com/chao921125"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chao921125/vue-vite"
  },
  "type": "module",
  "main": "index.html",
  "scripts": {
    "review": "npm run build && npm run dev",
    "serve": "npm run dev",
    "dev": "vp dev --host --open --mode development",
    "test": "vp dev --host --open --mode preview",
    "prod": "vp dev --host --open --mode production",
    "build": "npm run build:prod",
    "build:test": "vp build --mode preview",
    "build:prod": "vp build --mode production",
    "build:no-cache": "npm clean:cache && npm run build",
    "clean:cache": "rimraf yarn.lock && rimraf package.lock.json && rimraf pnpm-lock.yaml && rimraf node_modules && pnpm install",
    "clean:lib": "rimraf node_modules",
    "lint": "vp lint --fix",
    "lint:check": "vp lint && vp fmt --check",
    "lint:format": "vp lint --fix && vp fmt",
    "lint:lint-staged": "lint-staged",
    "lint:stylelint": "stylelint --cache --fix \"src/**/*.{vue,css,less,scss,postcss}\"",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "prepare": "husky",
    "commitlint": "commitlint --config .commitlintrc.js -e -V",
    "prepack": "npmignore --auto",
    "test:br": "http-server dist --cors --brotli -c-1",
    "test:gzip": "http-server dist --cors --gzip -c-1",
    "deploy:vercel": "pnpm build:prod && vercel --prod",
    "deploy:cf": "pnpm build:prod && wrangler pages deploy dist"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/components": "^14.3.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "@vueuse/metadata": "^14.3.0",
    "@vueuse/shared": "^14.3.0",
    "animate.css": "^4.1.1",
    "axios": "^1.18.1",
    "axios-mock-adapter": "^2.1.0",
    "core-js": "^3.49.0",
    "date-fns": "^4.4.0",
    "echarts": "^6.1.0",
    "echarts-gl": "^2.1.0",
    "echarts-wordcloud": "^2.1.0",
    "element-plus": "^2.14.3",
    "heic2any": "^0.0.4",
    "js-cookie": "^3.0.8",
    "js-use-core": "^1.3.1",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "qs": "^6.15.3",
    "scroll-seamless": "^2.0.3",
    "ua-parser-js": "^2.0.10",
    "vant": "^4.10.0",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.2.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@commitlint/format": "^20.5.0",
    "@commitlint/types": "^20.5.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@types/node": "^26.1.1",
    "@types/qs": "^6.15.1",
    "@vitejs/plugin-legacy": "^8.2.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/compiler-sfc": "^3.5.39",
    "@vue/shared": "^3.5.39",
    "browserslist": "^4.28.6",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "globals": "^17.7.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "less": "^4.6.7",
    "less-loader": "^12.3.3",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.20.0",
    "postcss": "^8.5.19",
    "postcss-html": "^1.8.1",
    "postcss-preset-env": "^11.3.2",
    "postcss-px-convert": "^1.4.3",
    "rimraf": "^6.1.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.101.0",
    "sass-loader": "^16.0.8",
    "stylelint": "^17.14.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "stylelint-scss": "^7.2.0",
    "terser": "^5.49.0",
    "typescript": "5.8.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-icons": "^23.0.1",
    "unplugin-vue-components": "^32.1.0",
    "unplugin-vue-define-options": "^3.1.3",
    "vite": "^8.1.4",
    "vite-plugin-cdn-import": "^1.0.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-ejs": "^2.0.0",
    "vite-plugin-full-reload": "^1.2.0",
    "vite-plugin-lqip": "^0.0.5",
    "vite-plugin-node-polyfills": "^0.26.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plus": "^0.1.24",
    "vite-svg-loader": "^5.1.1"
  },
  "overrides": {
    "typescript": "5.8.3"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,vue,astro,svelte}": "oxlint --no-error-on-unmatched-pattern",
    "*.css": "stylelint --fix"
  },
  "browserslist": [
    "defaults",
    "> 1%",
    "not dead",
    "not op_mini all",
    "last 2 versions",
    "Chrome > 107",
    "Edge > 107",
    "Firefox > 104",
    "Safari > 16.0",
    "not IE <= 11",
    "Android >= 6.0",
    "iOS > 10",
    "supports es6-module"
  ],
  "engines": {
    "node": "22.x",
    "npm": ">=10.8.2",
    "yarn": ">=3.8.7",
    "pnpm": ">=9.0.0"
  }
}

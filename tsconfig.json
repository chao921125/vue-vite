{
	"compilerOptions": {
		/* === 语言与语法 === */
		"target": "ESNext",
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "preserve",

		/* === 模块 === */
		"module": "ESNext",
		"moduleResolution": "bundler",
		"isolatedModules": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,

		/* === 严格性 === */
		"strict": true,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"forceConsistentCasingInFileNames": true,

		/* === 路径别名（TS 仅用于类型检查） === */
		"paths": {
			"@/*": ["./src/*"],
			"#/*": ["./class/*"]
		},

		/* === 输出 === */
		"outDir": "dist",
		"declaration": true,
		"declarationDir": "types",
		"declarationMap": true,
		"sourceMap": true,
		"removeComments": true,

		/* === 兼容性 === */
		"skipLibCheck": true,
		"allowJs": true,

		/* === 插件类型 === */
		"types": [
			"node",
			"vite/client",
			"vite-plugin-pwa/client",
			"vite-plugin-pwa/vue",
			"echarts",
			"qs"
		]
	},

	"include": [
		"src/**/*.ts",
		"src/**/*.tsx",
		"src/**/*.vue",
		"types/**/*",
		"build/**/*",
		"mock/**/*",
		"auto-imports.d.ts",
		"components.d.ts"
	],

	"exclude": [
		"node_modules",
		"dist",
		"cypress",
		"tests"
	]
}

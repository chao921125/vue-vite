# 兼容 peer dependencies
legacy-peer-deps = true

# 强制使用 lockfile version 9（pnpm 11.x 默认）
lockfile-version = 9

# 允许以下依赖运行构建脚本
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=sharp
only-built-dependencies[]=esbuild
only-built-dependencies[]=vue-demi

# 关闭供应链安全检查（允许使用刚发布的包）
minimum-release-age=0
supplyChainPolicy.minimumReleaseAge=0
enable-pre-post-scripts=true
unsafe-perm=true

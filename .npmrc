# auto-install-peers = true
# strict-peer-dependencies = false
# The above options are deprecated in newer versions of npm
legacy-peer-deps = true

# 锁定 TypeScript 版本，防止被更新到 6.x
overrides.typescript = 5.8.3

# 允许以下依赖运行构建脚本
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=core-js
only-built-dependencies[]=sharp
only-built-dependencies[]=esbuild
only-built-dependencies[]=vue-demi
